{\n  "name": "@getlatedev/node",\n  "version": "0.1.56",\n  "description": "The official Node.js library for the Late API",\n  "main": "dist/index.js",\n  "module": "dist/index.mjs",\n  "types": "dist/index.d.ts",\n  "sideEffects": false,\n  "exports": {\n    ".": {\n      "types": "./dist/index.d.ts",\n      "import": "./dist/index.mjs",\n      "require": "./dist/index.js"\n    },\n    "./_shims/*": {\n      "types": "./dist/_shims/*.d.ts",\n      "import": "./dist/_shims/*.mjs",\n      "require": "./dist/_shims/*.js"\n    }\n  },\n  "files": [\n    "dist",\n    "src",\n    "README.md",\n    "LICENSE"\n  ],\n  "scripts": {\n    "generate": "openapi-ts -i openapi.yaml -o src/generated -c @hey-api/client-fetch && npm run generate:client",\n    "generate:client": "npx tsx scripts/generate-client.ts",\n    "build": "tsup src/index.ts --format cjs,esm --dts --clean",\n    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",\n    "lint": "eslint src",\n    "typecheck": "tsc --noEmit",\n    "test": "vitest run",\n    "test:watch": "vitest",\n    "prepublishOnly": "npm run build",\n    "fetch-spec": "curl -o openapi.yaml https://zernio.com/openapi.yaml"\n  },\n  "keywords": [\n    "late",\n    "social-media",\n    "scheduling",\n    "api",\n    "sdk",\n    "instagram",\n    "tiktok",\n    "youtube",\n    "linkedin",\n    "twitter",\n    "x",\n    "facebook",\n    "pinterest",\n    "threads",\n    "bluesky",\n    "snapchat",\n    "telegram"\n  ],\n  "author": "Late <support@getlate.dev>",\n  "license": "Apache-2.0",\n  "repository": {\n    "type": "git",\n    "url": "git+https://github.com/getlatedev/late-node.git"\n  },\n  "homepage": "https://getlate.dev/docs/api",\n  "bugs": {\n    "url": "https://github.com/getlatedev/late-node/issues"\n  },\n  "engines": {\n    "node": ">=18"\n  },\n  "devDependencies": {\n    "@hey-api/client-fetch": "^0.6.0",\n    "@hey-api/openapi-ts": "^0.61.0",\n    "@types/node": "^20.11.0",\n    "@typescript-eslint/eslint-plugin": "^7.18.0",\n    "@typescript-eslint/parser": "^7.18.0",\n    "eslint": "^8.56.0",\n    "tsup": "^8.0.1",\n    "tsx": "^4.7.0",\n    "typescript": "^5.3.3",\n    "vitest": "^1.2.0",\n    "yaml": "^2.3.4"\n  }\n}\n